# .env — secrets & config for the Minecraft Bedrock server stack.
# Copy to .env (gitignored) and fill in, or just run:  just setup
# Only PLAYIT_SECRET_KEY is strictly required; everything else is optional.

# ── playit.gg tunnel (REQUIRED to let friends/consoles join) ──────────────────
# Sign up at https://playit.gg → New agent (Docker): https://playit.gg/account/agents/new-docker
# Copy the generated secret key (shown once) here.
PLAYIT_SECRET_KEY=

# ── server identity ───────────────────────────────────────────────────────────
# LEVEL_NAME MUST match the world folder under bedrock-data/worlds/.
SERVER_NAME="bedrock"
LEVEL_NAME="world"

# ── iPhone / phone push via ntfy.sh (optional; the default notification channel) ─
# Install the "ntfy" app, subscribe to a PRIVATE random topic, and put it here.
# Treat it like a password (anyone who knows it can read your pings).
NTFY_TOPIC=

# Opt-in macOS desktop notifications (off by default). 1 = also pop native alerts.
# NOTIFY_MACOS=1

# ── Discord webhooks (optional) — one per channel; unset categories fall back to URL ─
# Per channel: Edit Channel → Integrations → Webhooks → New Webhook → Copy URL.
DISCORD_WEBHOOK_PLAYER=          # #player-activity (joins/leaves)
DISCORD_WEBHOOK_SERVER_STATUS=   # #server-status (crash/tunnel/resource, up/down)
DISCORD_WEBHOOK_MONITOR=         # #monitoring (daily digest + uptime graph)
DISCORD_WEBHOOK_CHAT=            # #in-game-chat (in-game chat relay)
DISCORD_WEBHOOK_URL=             # optional catch-all for any category left unset

# ── 2-way chat: Discord #in-game-chat → Minecraft (optional) ───────────────────
# Create a bot at https://discord.com/developers/applications, enable the MESSAGE
# CONTENT INTENT, invite it (View Channels + Read Message History), then:
CHAT_BOT_TOKEN=                # the bot token (a password — never commit)
IN_GAME_CHAT_CHANNEL_ID=         # right-click #in-game-chat → Copy Channel ID (Developer Mode)

# ── uptime graph (optional) — healthchecks.io dead-man's-switch + graph source ──
# Free at https://healthchecks.io → add a check (1 min / 2 min grace).
HEALTHCHECK_URL=                 # https://hc-ping.com/<uuid>
HEALTHCHECK_API_KEY=             # read-write API key (project settings → API access)

# ── monitor tuning (optional; defaults in docker-compose.yml) ──────────────────
# MONITOR_MEM_ALERT=2500   # bedrock memory MiB before a high-memory alert
# MONITOR_CPU_ALERT=300    # bedrock CPU % before a high-CPU alert
