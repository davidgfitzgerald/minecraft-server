# ── Secrets — NEVER commit ──
# ...but DO track the (secret-free) template the wizard fills in (no trailing comments — gitignore treats them as part of the pattern)
.env
.env.*
!.env.example

# ── Local Claude Code overrides (permissions, etc.) ──
.claude/settings.local.json

# ── Runtime data: world saves, backups, logs, monitoring CSVs, scratch DBs ──
bedrock-data/

# ── Imported world archives ──
wetransfer_*/

# ── Temp / backup / OS cruft ──
*.tmp
.env.bak-*
.DS_Store

# Chat bot Python venv (discord.py) — local, never commit
scripts/.botvenv/

tools/setup/setup

# ── Generated artifacts (renders, scratch, py caches) — never commit ──
# world-map.png is a real render of the live world; scratch/caches are throwaway.
/world-map.png
/scratchpad/
__pycache__/
*.pyc
